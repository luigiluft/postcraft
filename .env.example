# ── Postcraft environment ───────────────────────────────────────────────
# Every adapter falls back to a deterministic FIXTURE when its key is absent,
# so the pipeline runs end-to-end with ZERO keys (demo mode). Add keys to
# promote each stage from fixture -> live provider.

# Provider selection (auto = live if key present, else fixture)
POSTCRAFT_LLM=auto            # auto | anthropic | fixture
POSTCRAFT_SCRAPER=auto        # auto | firecrawl | fixture
POSTCRAFT_SOCIAL=auto         # auto | apify | fixture
POSTCRAFT_IMAGEGEN=auto       # auto | fal | ideogram | fixture
POSTCRAFT_RENDERER=satori     # satori (no browser) | playwright

# ── Keys (all optional in demo mode) ────────────────────────────────────
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8

FIRECRAWL_API_KEY=

APIFY_TOKEN=

# Image generation (pick one; Ideogram is best for text-in-image)
FAL_KEY=
IDEOGRAM_API_KEY=

# ── Behaviour ───────────────────────────────────────────────────────────
POSTCRAFT_LOCALE=pt-BR        # default content locale
POSTCRAFT_OUT_DIR=runs        # where rendered kits land
POSTCRAFT_LOG=info            # debug | info | warn | error
